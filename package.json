{
  "name": "buy-a-buddy",
  "version": "2.0.0",
  "type": "module",
  "description": "An immersive 2D RPG with integrated mini-games",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch src/api/server.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "check": "npm run typecheck && npm run lint && npm run test",
    "audit": "npm run lint && npm run test && npm run build",
    "deploy": "npm run build && wrangler pages deploy dist --project-name buy-a-buddy",
    "deploy:api": "tsx src/api/server.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "howler": "^2.2.4",
    "phaser": "^3.88.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/howler": "^2.2.12",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitest/coverage-v8": "^3.1.3",
    "eslint": "^9.24.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "vite": "^6.2.6",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.1.3"
  }
}
